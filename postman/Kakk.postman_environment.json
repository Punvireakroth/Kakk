{
  "id": "kakk-postman-env",
  "name": "Kakk Local",
  "values": [
    {
      "key": "exchange_base",
      "value": "https://open.er-api.com/v6/latest",
      "type": "default",
      "enabled": true
    },
    {
      "key": "gemini_base",
